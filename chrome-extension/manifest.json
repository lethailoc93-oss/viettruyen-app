{
    "manifest_version": 3,
    "name": "SangTacViet Bypasser",
    "version": "1.0",
    "description": "Bypass Cloudflare by fetching via background pages and injecting tabs from a local WebSocket server.",
    "permissions": [
        "scripting",
        "tabs",
        "activeTab",
        "background"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    }
}